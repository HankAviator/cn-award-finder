{
  "name": "cn-award-finder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pwsh -NoProfile -File ./scripts/deploy-cloudflare.ps1",
    "deploy:dry-run": "pwsh -NoProfile -File ./scripts/deploy-cloudflare.ps1 -DryRun",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "playwright": "1.57.0",
    "tailwindcss": "4.1.11",
    "typescript": "5.8.3",
    "vitest": "4.1.9",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
